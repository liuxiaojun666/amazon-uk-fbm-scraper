# Request delay between products (milliseconds)
DELAY_MS=4000

# Short wait after each page load (milliseconds). Lower = faster startup; too low may miss content.
PAGE_SETTLE_MS=800

# Browser headless mode (true/false)
HEADLESS=true

# Output directory
OUTPUT_DIR=data

# Cache directory for seller profiles
CACHE_DIR=cache

# Max retries on page load failure
MAX_RETRIES=2

# VPN — most users: system VPN (Chrome works) → keep DISABLE_PROXY=true.
# Clash / local HTTP proxy only: set DISABLE_PROXY=false and uncomment HTTP_PROXY below.
DISABLE_PROXY=true
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# UK delivery postcode (London default). Use "london" or e.g. E1 6AN, SW1A1AA
DELIVERY_POSTCODE=SW1A 1AA

# Web UI port (npm run web)
WEB_PORT=3456
